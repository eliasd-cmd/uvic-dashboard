# --------------------------------------------------------------------------- #
# Plantilla de credenciales. Copia este archivo a `secrets.toml` (mismo dir)
# y rellena SOLO las plataformas que quieras conectar en vivo. Sin credenciales,
# el dashboard funciona con datos de ejemplo / caché.
#
# ⚠️ NUNCA subas secrets.toml a git (ya está en .gitignore).
# --------------------------------------------------------------------------- #

[google_ads]
developer_token = ""
client_id = ""
client_secret = ""
refresh_token = ""
login_customer_id = "3963262878"   # MCC Nuclio Digital School
customer_id = "2970533333"         # Cuenta UVic

[meta_ads]
access_token = ""                  # Token de la app / usuario del sistema
ad_account_id = "act_33542477"
api_version = "v21.0"

[ga4]
property_id = "properties/000000000"
# Pega aquí el JSON del Service Account (como sub-tabla):
[ga4.service_account]
type = "service_account"
project_id = ""
private_key_id = ""
private_key = ""
client_email = ""
client_id = ""
token_uri = "https://oauth2.googleapis.com/token"

[hubspot]
access_token = ""                  # Private App token (pat-...)
# Nombres de propiedad de contacto en TU portal (ajústalos):
prop_campana = "hs_analytics_source_data_1"
prop_estado = "hs_lead_status"
